{
  "name": "mednemo-mcp-apps",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:ui": "vite",
    "build": "npm run build:apps && tsc -p tsconfig.server.json --noEmit",
    "build:apps": "node scripts/build-apps.js",
    "start": "tsx src/server.ts",
    "studio": "npx mcp-app-studio"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.0"
  }
}
